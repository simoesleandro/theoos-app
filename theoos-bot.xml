<service>
  <id>theoos-bot</id>
  <name>ThéoOS - Bot Telegram</name>
  <description>Serviço do Bot do Telegram ThéoOS. Inicia com o Windows.</description>
  
  <executable>C:\Users\stife\AppData\Local\Programs\Python\Python312\python.exe</executable>
  <arguments>bot.py</arguments>
  
  <workingdirectory>%BASE%</workingdirectory>
  <startmode>Automatic</startmode>
  <delayedAutoStart>true</delayedAutoStart>
  
  <depend>Tcpip</depend>
  <depend>Dnscache</depend>
  
  <env name="PYTHONUNBUFFERED" value="1"/>
  <env name="THEOOS_SERVICE" value="1"/>
  
  <logpath>%BASE%\logs</logpath>
  <log mode="roll-by-size">
    <sizeThreshold>10240</sizeThreshold>
    <keepFiles>8</keepFiles>
  </log>
  
  <onfailure action="restart" delay="15 sec"/>
  <onfailure action="restart" delay="30 sec"/>
  <onfailure action="restart" delay="60 sec"/>
  <resetfailure>1 hour</resetfailure>
  
  <stoptimeout>20 sec</stoptimeout>
  <starttimeout>120 sec</starttimeout>
</service>