# ThéoOS — copie para .env
# Gere uma chave longa com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
WEB_PIN=

TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
# URL do painel na rede local (botão "Abrir no app" no Telegram; não use localhost)
THEOOS_WEB_URL=http://192.168.0.100:5000

GEMINI_API_KEY=

# Nível de log: DEBUG, INFO, WARNING, ERROR (padrão: INFO)
THEOOS_LOG_LEVEL=INFO
